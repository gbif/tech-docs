#. type: Title =
#: en/data-processing/modules/ROOT/pages/ingestion-pills.adoc:5
#, no-wrap
msgid "Ingestion steps for Occurrence and Event datasets"
msgstr ""

#. type: Plain text
#: en/data-processing/modules/ROOT/pages/ingestion-pills.adoc:8
#: en/data-publishing/modules/ROOT/pages/LSID-lookup.adoc:13
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:14
