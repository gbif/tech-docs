#. type: Title ===
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:36
#, no-wrap
msgid "EML: Ecological Metadata Language "
msgstr ""

#. type: Plain text
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:39
msgid "Ecological Metadata Language, or *EML*, is a metadata standard that records information about ecological datasets in a series of modular and extensible XML document types. All of the descriptions of datasets in GBIF.org rely on 'metadata'—that is, the information about data—using the open-source EML standard, which is administered and maintained by https://knb.ecoinformatics.org[The Knowledge Network for Biocomplexity]. Each Darwin Core Archive includes as one of its components an EML file (written in XML format)."
msgstr ""

#. type: Plain text
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:41
msgid "https://ipt.gbif.org/manual/en/ipt/latest/gbif-metadata-profile[GBIF Metadata Profile: How-to Guide]"
msgstr ""

#. type: Plain text
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:42
msgid "https://eml.ecoinformatics.org/[EML standard]"
msgstr ""

#. type: Title ===
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:43
#, no-wrap
msgid "BioCASe / ABCD "
msgstr ""

#. type: Plain text
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:46
msgid "The http://www.biocase.org[Biological Collection Access Service], commonly referred to as *BioCASe*, is an international network linking biological collections data from natural history museums, botanical/zoological gardens and research institutions. BioCASe relies on the https://www.tdwg.org/standards/abcd/[Access to Biological Collections Data (ABCD) data exchange standard], which TDWG also administers."
msgstr ""

#. type: Plain text
#: en/data-publishing/modules/ROOT/pages/standards-publishing.adoc:48
msgid "https://www.biocase.org/products/protocols/[BioCASe Protocol]"
msgstr ""

